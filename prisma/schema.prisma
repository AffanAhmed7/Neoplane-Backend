generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema", "fullTextSearch", "extendedIndexes"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["neoplane"]
}

// --- ENUMS ---

enum UserStatus {
  ONLINE
  OFFLINE
  AWAY
  DND

  @@schema("neoplane")
}

enum ConversationType {
  DIRECT
  GROUP
  CHANNEL

  @@schema("neoplane")
}

enum MessageType {
  TEXT
  IMAGE
  FILE
  SYSTEM

  @@schema("neoplane")
}

enum ParticipantRole {
  MEMBER
  ADMIN

  @@schema("neoplane")
}

// --- MODELS ---

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  username     String     @unique
  password     String?
  firebaseUid  String?    @unique
  provider     String     @default("email")
  avatar       String?
  bio          String?    @db.Text
  banner       String?
  status       UserStatus @default(OFFLINE)
  customStatus String?
  refreshToken String?
  lastSeen     DateTime   @default(now())
  pinnedChannels String[]   @default([])
  mutedChannels  String[]   @default([])
  mutedUsers     String[]   @default([])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  // Relations
  participatedIn       ConversationParticipant[]
  createdConversations Conversation[]            @relation("ConversationCreator")
  sentMessages         Message[]
  reactions            MessageReaction[]
  messageReads         MessageRead[]
  notifications        Notification[]
  sentRequests         FriendRequest[]           @relation("SentRequests")
  receivedRequests     FriendRequest[]           @relation("ReceivedRequests")
  userFriends          Friend[]                  @relation("UserFriends")
  friendOf             Friend[]                  @relation("FriendOf")
  sentInvites          ChannelInvite[]            @relation("SentInvites")
  receivedInvites      ChannelInvite[]            @relation("ReceivedInvites")
  joinRequests         JoinRequest[]

  @@index([username])
  @@index([email])
  @@schema("neoplane")
}

model Conversation {
  id          String           @id @default(cuid())
  name        String?
  type        ConversationType @default(DIRECT)
  isPrivate   Boolean          @default(false)
  isPublic    Boolean          @default(true)
  isHidden    Boolean          @default(false)
  description String?          @db.Text
  heroImage   String?
  category    String?
  creatorId   String
  parentId    String?
  createdAt   DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  // Relations
  createdBy    User                      @relation("ConversationCreator", fields: [creatorId], references: [id])
  parent       Conversation?             @relation("ConversationHierarchy", fields: [parentId], references: [id])
  children     Conversation[]            @relation("ConversationHierarchy")
  participants ConversationParticipant[]
  messages     Message[]
  messageReads MessageRead[]
  channelInvites ChannelInvite[]
  joinRequests   JoinRequest[]

  @@index([creatorId])
  @@schema("neoplane")
}

model ConversationParticipant {
  id             String          @id @default(cuid())
  userId         String
  conversationId String
  role           ParticipantRole @default(MEMBER)
  joinedAt       DateTime        @default(now())

  // Relations
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([userId, conversationId])
  @@index([userId])
  @@index([conversationId])
  @@schema("neoplane")
}

model Message {
  id             String      @id @default(cuid())
  content        String?     @db.Text
  type           MessageType @default(TEXT)
  fileUrl        String?
  fileName       String?
  fileSize       Int?
  senderId       String
  conversationId String
  parentId       String?
  isPinned       Boolean     @default(false)
  isEdited       Boolean     @default(false)
  isDeleted      Boolean     @default(false)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  // Relations
  sender       User              @relation(fields: [senderId], references: [id], onDelete: Cascade)
  conversation Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  parent       Message?          @relation("MessageThreads", fields: [parentId], references: [id])
  replies      Message[]         @relation("MessageThreads")
  reactions    MessageReaction[]

  @@index([conversationId, createdAt])
  @@index([senderId, createdAt])
  @@index([parentId])
  @@schema("neoplane")
}

model MessageReaction {
  id        String   @id @default(cuid())
  emoji     String
  userId    String
  messageId String
  createdAt DateTime @default(now())

  // Relations
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([userId, messageId, emoji])
  @@index([messageId])
  @@schema("neoplane")
}

model MessageRead {
  id                String   @id @default(cuid())
  userId            String
  conversationId    String
  lastReadMessageId String
  updatedAt         DateTime @default(now())

  // Relations
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([userId, conversationId])
  @@index([userId, conversationId])
  @@schema("neoplane")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  entityId  String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@schema("neoplane")
}

enum FriendRequestStatus {
  PENDING
  ACCEPTED
  DECLINED

  @@schema("neoplane")
}

model FriendRequest {
  id         String              @id @default(cuid())
  senderId   String
  receiverId String
  status     FriendRequestStatus @default(PENDING)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  // Relations
  sender   User @relation("SentRequests", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedRequests", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([senderId])
  @@index([receiverId])
  @@schema("neoplane")
}

model Friend {
  id        String   @id @default(cuid())
  userId    String
  friendId  String
  createdAt DateTime @default(now())

  // Relations
  user   User @relation("UserFriends", fields: [userId], references: [id], onDelete: Cascade)
  friend User @relation("FriendOf", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
  @@index([userId])
  @@schema("neoplane")
}

enum ChannelInviteStatus {
  PENDING
  ACCEPTED
  DECLINED

  @@schema("neoplane")
}

enum JoinRequestStatus {
  PENDING
  APPROVED
  DECLINED

  @@schema("neoplane")
}

model JoinRequest {
  id             String            @id @default(cuid())
  userId         String
  conversationId String
  status         JoinRequestStatus @default(PENDING)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  // Relations
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([userId, conversationId])
  @@index([conversationId])
  @@schema("neoplane")
}

model ChannelInvite {
  id             String              @id @default(cuid())
  conversationId String
  inviterId      String
  inviteeId      String
  status         ChannelInviteStatus @default(PENDING)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  // Relations
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  inviter      User         @relation("SentInvites", fields: [inviterId], references: [id], onDelete: Cascade)
  invitee      User         @relation("ReceivedInvites", fields: [inviteeId], references: [id], onDelete: Cascade)

  @@unique([inviteeId, conversationId])
  @@index([inviteeId, status])
  @@index([conversationId])
  @@schema("neoplane")
}
